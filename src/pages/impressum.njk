---
layout: base.njk
title: Impressum · EN/AK
description: Impressum / legal notice for EN/AK.
---

    <section class="page-hero container">
      <div class="page-hero__light deco"></div>
      <span class="eyebrow page-hero__eyebrow" data-reveal="fade" data-en="{{ impressum.hero.eyebrow.en }}" data-de="{{ impressum.hero.eyebrow.de }}">{{ impressum.hero.eyebrow.en }}</span>
      <h1 class="page-hero__title ink-shine" data-reveal data-en="{{ impressum.hero.title.en }}" data-de="{{ impressum.hero.title.de }}">{{ impressum.hero.title.en }}</h1>
    </section>

    <section class="section--tight">
      <div class="container measure stack-lg" data-reveal-group="90">
        <div class="stack" data-reveal>
          <h2 style="font-size: var(--t-h3)">{{ impressum.provider.heading }}</h2>
          <p class="muted">{{ impressum.provider.name }}</p>
          <p class="muted">{{ impressum.provider.street }}</p>
          <p class="muted">{{ impressum.provider.city }}</p>
        </div>
        <div class="stack" data-reveal>
          <h2 style="font-size: var(--t-h3)">{{ impressum.contact.heading }}</h2>
          <p class="muted">{{ impressum.contact.phone }}</p>
          <p class="muted">{{ impressum.contact.email }}</p>
        </div>
        <p class="muted" style="font-size: var(--t-small)" data-reveal>Quelle: {{ impressum.source }}</p>
      </div>
    </section>
