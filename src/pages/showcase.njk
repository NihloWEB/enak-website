---
layout: base.njk
title: Showcase · EN/AK
description: Selected projects by EN/AK — web design, design and interfaces.
---

    <section class="page-hero container">
      <div class="page-hero__light deco"></div>
      <span class="eyebrow page-hero__eyebrow" data-reveal="fade" data-en="{{ showcase.hero.eyebrow.en }}" data-de="{{ showcase.hero.eyebrow.de }}">{{ showcase.hero.eyebrow.en }}</span>
      <h1 class="page-hero__title ink-shine" data-reveal data-en="{{ showcase.hero.title.en }}" data-de="{{ showcase.hero.title.de }}">{{ showcase.hero.title.en }}</h1>
      <p class="page-hero__lead" data-reveal data-en="{{ showcase.hero.lead.en }}" data-de="{{ showcase.hero.lead.de }}">{{ showcase.hero.lead.en }}</p>
      <div class="filters" data-filters role="tablist" aria-label="Filter projects" data-reveal="fade">
        {%- for f in showcase.filters %}
        <button type="button" class="filter-chip{% if loop.first %} is-active{% endif %}" data-filter="{{ f.key }}" data-en="{{ f.en }}" data-de="{{ f.de }}">{{ f.en }}</button>
        {%- endfor %}
      </div>
    </section>

    <section class="section--tight">
      <div class="container">
        <div class="grid-3" data-reveal-group="80" data-project-grid>
          {%- for t in showcase.tiles %}
          <a class="tile tile--grid" href="#proj-{{ t.slug }}" data-open="{{ t.slug }}" data-category="{{ t.category }}" data-reveal>
            <div class="tile__media deco" style="--tile-angle:{{ t.angle }}deg">{% if t.thumb %}<img class="tile__thumb" src="{{ t.thumb }}" alt="" loading="lazy" />{% endif %}</div>
            <div class="tile__overlay deco"></div>
            <span class="tile__tag" data-en="{{ t.tag.en }}" data-de="{{ t.tag.de }}">{{ t.tag.en }}</span>
            <h3 class="tile__title">{{ t.title }}</h3>
            <p class="tile__meta" data-en="{{ t.meta.en }}" data-de="{{ t.meta.de }}">{{ t.meta.en }}</p>
            <span class="tile__open" aria-hidden="true" data-en="View project" data-de="Projekt ansehen">View project</span>
          </a>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="cta-band__inner glass glass--strong" data-tilt="3" data-reveal="scale">
          <div class="cta-band__glow deco"></div>
          <h2 class="cta-band__title" data-en="{{ showcase.cta.title.en }}" data-de="{{ showcase.cta.title.de }}">{{ showcase.cta.title.en }}</h2>
          <p class="cta-band__sub" data-en="{{ showcase.cta.sub.en }}" data-de="{{ showcase.cta.sub.de }}">{{ showcase.cta.sub.en }}</p>
          <div class="cta-band__actions">
            <a class="btn btn--solid btn--lg" href="{{ showcase.cta.primary.url }}" data-magnetic="0.4"><span data-en="{{ showcase.cta.primary.en }}" data-de="{{ showcase.cta.primary.de }}">{{ showcase.cta.primary.en }}</span><svg class="btn__arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== Project lightbox (overlay) ===================== -->
    <div class="lightbox" data-lightbox aria-hidden="true" role="dialog" aria-modal="true">
      <div class="lightbox__backdrop" data-lightbox-close></div>
      <button class="lightbox__close icon-btn" data-lightbox-close data-en-aria="Close project" data-de-aria="Projekt schließen" aria-label="Close project">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
      <div class="lightbox__scroll">
        {%- for t in showcase.tiles %}
        <article class="project" id="proj-{{ t.slug }}" data-panel="{{ t.slug }}" hidden>
          <span class="eyebrow" data-en="{{ t.tag.en }}" data-de="{{ t.tag.de }}">{{ t.tag.en }}</span>
          <h2 class="project__title">{{ t.title }}</h2>
          <p class="project__meta" data-en="{{ t.meta.en }}" data-de="{{ t.meta.de }}">{{ t.meta.en }}</p>
          <p class="project__desc lead" data-en="{{ t.description.en }}" data-de="{{ t.description.de }}">{{ t.description.en }}</p>
          {%- for rail in t.gallery %}
          <div class="project__rail">
            {%- for img in rail.images %}
            <img src="{{ img }}" alt="" loading="lazy" />
            {%- endfor %}
          </div>
          {%- endfor %}
        </article>
        {%- endfor %}
      </div>
    </div>
