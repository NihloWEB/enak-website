---
layout: base.njk
title: About · EN/AK
description: About EN/AK — who's behind the projects.
---

    <section class="page-hero container">
      <div class="page-hero__light deco"></div>
      <span class="eyebrow page-hero__eyebrow" data-reveal="fade" data-en="{{ about.hero.eyebrow.en }}" data-de="{{ about.hero.eyebrow.de }}">{{ about.hero.eyebrow.en }}</span>
      <h1 class="page-hero__title ink-shine" data-reveal data-en="{{ about.hero.title.en }}" data-de="{{ about.hero.title.de }}">{{ about.hero.title.en }}</h1>
      <p class="page-hero__lead" data-reveal data-en="{{ about.hero.lead.en }}" data-de="{{ about.hero.lead.de }}">{{ about.hero.lead.en }}</p>
    </section>

    <!-- ===================== 3D book (scroll to leaf through) ===================== -->
    <section class="book-section" data-book>
      <div class="book-sticky">
        <canvas class="book-canvas" data-book-canvas aria-hidden="true"></canvas>
        <span class="book-hint" data-en="Scroll to leaf through" data-de="Zum Blättern scrollen">Scroll to leaf through</span>
      </div>

      <div class="container book-pages" data-book-pages>
        <article class="book-page">
          <span data-role="eyebrow" data-en="{{ about.hero.eyebrow.en }}" data-de="{{ about.hero.eyebrow.de }}">{{ about.hero.eyebrow.en }}</span>
          <h2 data-role="title" data-en="{{ about.hero.title.en }}" data-de="{{ about.hero.title.de }}">{{ about.hero.title.en }}</h2>
          <p data-role="body" data-en="{{ about.statement.en }}" data-de="{{ about.statement.de }}">{{ about.statement.en }}</p>
        </article>

        {%- for v in about.values.items %}
        <article class="book-page">
          <span data-role="eyebrow" data-en="{{ about.values.eyebrow.en }}" data-de="{{ about.values.eyebrow.de }}">{{ about.values.eyebrow.en }}</span>
          <h2 data-role="title" data-en="{{ v.title.en }}" data-de="{{ v.title.de }}">{{ v.title.en }}</h2>
          <p data-role="body" data-en="{{ v.text.en }}" data-de="{{ v.text.de }}">{{ v.text.en }}</p>
        </article>
        {%- endfor %}

        {%- for m in about.milestones.steps %}
        <article class="book-page">
          <span data-role="eyebrow" data-en="{{ m.no }}" data-de="{{ m.no }}">{{ m.no }}</span>
          <h2 data-role="title" data-en="{{ m.title.en }}" data-de="{{ m.title.de }}">{{ m.title.en }}</h2>
          <p data-role="body" data-en="{{ m.text.en }}" data-de="{{ m.text.de }}">{{ m.text.en }}</p>
        </article>
        {%- endfor %}
      </div>
    </section>

    <section class="section--tight">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow" data-en="{{ about.team.eyebrow.en }}" data-de="{{ about.team.eyebrow.de }}">{{ about.team.eyebrow.en }}</span>
          <h2 class="section-head__title" data-en="{{ about.team.title.en }}" data-de="{{ about.team.title.de }}">{{ about.team.title.en }}</h2>
        </div>
        <div class="grid-4" data-reveal-group="80">
          {%- for m in about.team.members %}
          <article class="member" data-reveal><span class="member__avatar">{{ m.avatar }}</span><span class="member__name" data-en="{{ m.name.en }}" data-de="{{ m.name.de }}">{{ m.name.en }}</span><span class="member__role" data-en="{{ m.role.en }}" data-de="{{ m.role.de }}">{{ m.role.en }}</span></article>
          {%- endfor %}
        </div>
      </div>
    </section>
